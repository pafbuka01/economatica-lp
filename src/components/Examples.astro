---
import type { Dict } from '../lib/i18n';
interface Props { t: Dict; }
const { t } = Astro.props;
const E = t.examples;
---
<section id="docs">
  <div class="container">
    <div class="section-head">
      <div class="eyebrow">{E.eyebrow}</div>
      <h2 style="margin-top:16px;">{E.h2}</h2>
      <p>{E.sub}</p>
    </div>

    <div class="code" id="examples-code">
      <div class="code-head">
        <div style="display:flex;align-items:center;gap:12px;">
          <div class="code-dots"><span></span><span></span><span></span></div>
          <span class="code-file" id="examples-filename">request.sh</span>
        </div>
        <div class="lang-tabs">
          <button class="lang-tab active" data-lang="curl" data-file="request.sh">cURL</button>
          <button class="lang-tab" data-lang="javascript" data-file="client.js">JavaScript</button>
          <button class="lang-tab" data-lang="python" data-file="client.py">Python</button>
        </div>
      </div>
      <div class="code-body">
        <pre id="examples-pre" set:html={`<span class="tok-cmt"># Buscar notícias sobre PETR4 com highlight</span>
<span class="tok-kw">curl</span> --request GET <span class="tok-str">"https://3lcj3yysx7.execute-api.us-east-1.amazonaws.com/prod/v1/news?ticker=PETR4&amp;highlight=1&amp;size=5"</span> \\
  -H <span class="tok-str">"x-api-key: $ECO_API_KEY"</span> \\
  -H <span class="tok-str">"x-timestamp: $ECO_TS"</span> \\
  -H <span class="tok-str">"x-signature: $ECO_SIGNATURE"</span>`}></pre>
      </div>
    </div>

    <div style="display:flex;gap:16px;margin-top:24px;flex-wrap:wrap;align-items:center;">
      <a href="http://econewsapi-prod-alb-1210485769.us-east-1.elb.amazonaws.com/docs" target="_blank" rel="noopener noreferrer" class="btn btn-ghost">{t.footer.docsCta}</a>
      <span class="mono" style="font-size:12px;color:var(--fg-subtle);">
        Auth: x-api-key &middot; x-timestamp &middot; x-signature (HMAC-SHA256)
      </span>
    </div>
  </div>
</section>

<script is:inline>
(function() {
  var codeSnippets = {
    curl: '<span class="tok-cmt"># Buscar notícias sobre PETR4 com highlight</span>\n<span class="tok-kw">curl</span> --request GET <span class="tok-str">"https://3lcj3yysx7.execute-api.us-east-1.amazonaws.com/prod/v1/news?ticker=PETR4&amp;highlight=1&amp;size=5"</span> \\\n  -H <span class="tok-str">"x-api-key: $ECO_API_KEY"</span> \\\n  -H <span class="tok-str">"x-timestamp: $ECO_TS"</span> \\\n  -H <span class="tok-str">"x-signature: $ECO_SIGNATURE"</span>',
    javascript: '<span class="tok-cmt">// Assumindo assinatura HMAC calculada no seu backend</span>\n<span class="tok-kw">const</span> url = <span class="tok-str">"https://3lcj3yysx7.execute-api.us-east-1.amazonaws.com/prod/v1/news?source=InfoMoney,Valor&amp;size=10"</span>;\n\n<span class="tok-kw">const</span> res = <span class="tok-kw">await</span> <span class="tok-fn">fetch</span>(url, {\n  <span class="tok-key">headers</span>: {\n    <span class="tok-str">"x-api-key"</span>: process.env.<span class="tok-str">ECO_API_KEY</span>,\n    <span class="tok-str">"x-timestamp"</span>: timestamp,\n    <span class="tok-str">"x-signature"</span>: signature,\n  },\n});\n\n<span class="tok-kw">const</span> data = <span class="tok-kw">await</span> res.<span class="tok-fn">json</span>();',
    python: '<span class="tok-kw">import</span> requests\n\nurl = <span class="tok-str">"https://3lcj3yysx7.execute-api.us-east-1.amazonaws.com/prod/v1/news/search"</span>\nparams = {<span class="tok-str">"q"</span>: <span class="tok-str">"dividendos Petrobras"</span>, <span class="tok-str">"size"</span>: <span class="tok-num">10</span>}\nheaders = {\n    <span class="tok-str">"x-api-key"</span>: ECO_API_KEY,\n    <span class="tok-str">"x-timestamp"</span>: timestamp,\n    <span class="tok-str">"x-signature"</span>: signature,\n}\n\nresp = requests.<span class="tok-fn">get</span>(url, params=params, headers=headers)\nprint(resp.<span class="tok-fn">json</span>())'
  };

  var tabs = document.querySelectorAll('.lang-tab');
  var pre = document.getElementById('examples-pre');
  var filename = document.getElementById('examples-filename');

  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      tabs.forEach(function(t) { t.classList.remove('active'); });
      tab.classList.add('active');
      var lang = tab.getAttribute('data-lang');
      var file = tab.getAttribute('data-file');
      if (pre && codeSnippets[lang]) pre.innerHTML = codeSnippets[lang];
      if (filename) filename.textContent = file;
    });
  });
})();
</script>
