---
import type { Dict } from '../lib/i18n';
interface Props { t: Dict; }
const { t } = Astro.props;
const h = t.hero;
const codeHtml = `<span class="tok-cmt">// Requisição autenticada com HMAC-SHA256</span>
<span class="tok-kw">const</span> url = <span class="tok-str">'https://3lcj3yysx7.execute-api.us-east-1.amazonaws.com/prod/v1/news?ticker=PETR4&amp;size=5'</span>;

<span class="tok-kw">const</span> res = <span class="tok-kw">await</span> <span class="tok-fn">fetch</span>(url, {
  <span class="tok-key">headers</span>: {
    <span class="tok-str">'x-api-key'</span>: process.env.<span class="tok-str">ECO_API_KEY</span>,
    <span class="tok-str">'x-timestamp'</span>: timestamp,
    <span class="tok-str">'x-signature'</span>: signature,
  },
});

<span class="tok-kw">const</span> data = <span class="tok-kw">await</span> res.<span class="tok-fn">json</span>();`;
---
<section class="hero" id="top">
  <div class="container hero-grid">
    <div>
      <div class="eyebrow">{h.eyebrow}</div>
      <h1 style="margin-top:18px;">
        {h.h1_pre} <strong><em style="font-style:normal;">{h.h1_em}</em></strong><br/>
        {h.h1_post}
      </h1>
      <p class="hero-sub">{h.sub}</p>
      <div class="hero-ctas">
        <a href="#contact" class="btn btn-primary btn-lg">{h.cta_sales}</a>
        <a href="http://econewsapi-prod-alb-1210485769.us-east-1.elb.amazonaws.com/docs" target="_blank" rel="noopener noreferrer" class="btn btn-ghost btn-lg">{h.cta_docs}</a>
      </div>
      <div class="hero-meta hero-meta-fade">
        <div class="hero-meta-item"><span class="num">{h.m1_num}</span><span class="lbl">{h.m1_lbl}</span></div>
        <div class="hero-meta-item"><span class="num">{h.m2_num}</span><span class="lbl">{h.m2_lbl}</span></div>
        <div class="hero-meta-item"><span class="num">{h.m3_num}</span><span class="lbl">{h.m3_lbl}</span></div>
        <div class="hero-meta-item"><span class="num">{h.m4_num}</span><span class="lbl">{h.m4_lbl}</span></div>
      </div>
    </div>

    <div class="hero-viz">
      <div class="code viz-code">
        <div class="code-head">
          <div style="display:flex;align-items:center;gap:12px;">
            <div class="code-dots"><span></span><span></span><span></span></div>
            <span class="code-file">request.js</span>
          </div>
          <span class="chip live" style="height:22px;font-size:10px;"><span class="chip-dot"></span>hmac auth</span>
        </div>
        <div class="code-body">
          <pre set:html={codeHtml}></pre>
        </div>
      </div>
      <div class="viz-stream">
        <div class="viz-stream-head">
          <span class="eyebrow" style="font-size:10px;">REST endpoints</span>
          <span class="mono" style="font-size:10px;color:var(--fg-subtle);">GET &middot; /v1/news</span>
        </div>
        <div class="stream-item" style="animation-delay:0s;">
          <div class="stream-meta">
            <span class="ticker">PETR4</span>
            <span>14:32:08</span>
            <span class="sent-pos" style="margin-left:auto;">&#9679; positive</span>
          </div>
          <div class="stream-head">/v1/news?ticker=PETR4&amp;highlight=1 retorna notícias paginadas com sentiment, tickers e entities por plano</div>
        </div>
        <div class="stream-item" style="animation-delay:0.1s;">
          <div class="stream-meta">
            <span class="ticker">VALE3</span>
            <span>14:31:42</span>
            <span class="sent-pos" style="margin-left:auto;">&#9679; growth+</span>
          </div>
          <div class="stream-head">Autenticação exige x-api-key, x-timestamp e x-signature calculada via HMAC-SHA256</div>
        </div>
        <div class="stream-item" style="animation-delay:0.2s;">
          <div class="stream-meta">
            <span class="ticker">ITUB4</span>
            <span>14:30:19</span>
            <span class="sent-neu" style="margin-left:auto;">&#9679; enterprise</span>
          </div>
          <div class="stream-head">Taxonomy, related news e stats ficam disponíveis em rotas próprias da documentação técnica</div>
        </div>
      </div>
    </div>
  </div>
</section>
