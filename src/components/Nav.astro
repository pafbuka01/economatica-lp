---
import type { Dict } from '../lib/i18n';
interface Props { t: Dict; lang: string; }
const { t, lang } = Astro.props;
const langMap: Record<string, string> = { 'pt-BR': '/', en: '/en', es: '/es' };
---
<nav class="nav" id="nav">
  <div class="container nav-inner">
    <a class="logo" href="#top">
      <img src="/economatica-logo.svg" alt="Economatica" style="height:20px;display:block;" class="logo-img" />
      <span class="logo-sub">News API</span>
    </a>
    <div class="nav-links">
      <a href="#playground">{t.nav.product}</a>
      <a href="#coverage">{t.nav.coverage}</a>
      <a href="#usecases">{t.nav.usecases}</a>
      <a href="#docs">{t.nav.docs}</a>
      <a href="#pricing">{t.nav.pricing}</a>
    </div>
    <div class="nav-right">
      <select class="lang-select" id="lang-select">
        <option value="/" selected={lang === 'pt-BR'}>PT</option>
        <option value="/en" selected={lang === 'en'}>EN</option>
        <option value="/es" selected={lang === 'es'}>ES</option>
      </select>
      <a href="#contact" class="btn btn-primary btn-sm">{t.nav.talk}</a>
    </div>
  </div>
</nav>

<script is:inline>
  // Scroll detection for nav border
  (function() {
    const nav = document.getElementById('nav');
    if (!nav) return;
    function onScroll() {
      if (window.scrollY > 12) {
        nav.classList.add('scrolled');
      } else {
        nav.classList.remove('scrolled');
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // Language select navigation
    var sel = document.getElementById('lang-select');
    if (sel) {
      sel.addEventListener('change', function() {
        window.location.href = sel.value;
      });
    }
  })();
</script>
