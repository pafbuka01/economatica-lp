---
import type { Dict } from '../lib/i18n';
interface Props { t: Dict; }
const { t } = Astro.props;
const F = t.footer;
---
<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <div class="logo" style="margin-bottom:16px;">
          <img src="/economatica-logo.svg" alt="Economatica" style="height:20px;" class="logo-img" />
          <span class="logo-sub">News API</span>
        </div>
        <p style="font-size:13px;max-width:320px;color:var(--fg-muted);">
          Four decades of financial data infrastructure, now delivered via API.
        </p>
      </div>
      <div class="footer-col">
        <h5>{F.product}</h5>
        <ul>
          <li><a href="#playground">Playground</a></li>
          <li><a href="#coverage">Coverage</a></li>
          <li><a href="#compare">vs. Wires</a></li>
          <li><a href="#contact">Pricing</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h5>{F.developers}</h5>
        <ul>
          <li><a href="#docs">{F.docsCta}</a></li>
          <li><a href="#docs">API Reference</a></li>
          <li><a href="#docs">SDKs</a></li>
          <li><a href="#docs">Status</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h5>{F.company}</h5>
        <ul>
          <li><a href="#">Economatica</a></li>
          <li><a href="#">Mover &middot; TC S.A.</a></li>
          <li><a href="#">Security</a></li>
          <li><a href="#">Contact</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>{F.copy}</p>
      <p class="mono" style="font-size:12px;">v1.0 &middot; api.econews.economatica.com</p>
    </div>
  </div>
</footer>
