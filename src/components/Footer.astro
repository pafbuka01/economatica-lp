---
import type { Dict } from '../lib/i18n';
interface Props { t: Dict; }
const { t } = Astro.props;
const F = t.footer;
---
<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <div class="logo" style="margin-bottom:16px;">
          <img src="/economatica-logo.svg" alt="Economatica" style="height:20px;" class="logo-img" />
          <span class="logo-sub">News API</span>
        </div>
        <p style="font-size:13px;max-width:320px;color:var(--fg-muted);">
          {F.tagline}
        </p>
      </div>
      <div class="footer-col">
        <h5>{F.product}</h5>
        <ul>
          <li><a href="#playground">{F.playground}</a></li>
          <li><a href="#coverage">{F.coverage}</a></li>
          <li><a href="#compare">{F.compare}</a></li>
          <li><a href="#contact">{F.pricing}</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h5>{F.developers}</h5>
        <ul>
          <li><a href="http://econewsapi-prod-alb-1210485769.us-east-1.elb.amazonaws.com/docs" target="_blank" rel="noopener noreferrer">{F.docsCta}</a></li>
          <li><a href="http://econewsapi-prod-alb-1210485769.us-east-1.elb.amazonaws.com/docs" target="_blank" rel="noopener noreferrer">{F.apiReference}</a></li>
          <li><a href="http://econewsapi-prod-alb-1210485769.us-east-1.elb.amazonaws.com/docs" target="_blank" rel="noopener noreferrer">{F.sdks}</a></li>
          <li><a href="http://econewsapi-prod-alb-1210485769.us-east-1.elb.amazonaws.com/docs" target="_blank" rel="noopener noreferrer">{F.status}</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h5>{F.company}</h5>
        <ul>
          <li><a href="https://economatica.com" target="_blank" rel="noopener noreferrer">Economatica</a></li>
          <li><a href="#">{F.security}</a></li>
          <li><a href="#contact">{F.contact}</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>{F.copy}</p>
      <p class="mono" style="font-size:12px;">{F.versionHost}</p>
    </div>
  </div>
</footer>
