---
import type { Dict } from '../lib/i18n';
interface Props { t: Dict; }
const { t } = Astro.props;
const feats = t.features.items;
const iconPaths = [
  'M20.59 13.41 11 22H2v-9l9.59-9.59a2 2 0 0 1 2.83 0l6.17 6.17a2 2 0 0 1 0 2.83z',
  'M12 3a3 3 0 0 0-3 3v1a3 3 0 0 0-3 3v1a3 3 0 0 0 0 6v1a3 3 0 0 0 3 3h6a3 3 0 0 0 3-3v-1a3 3 0 0 0 0-6v-1a3 3 0 0 0-3-3V6a3 3 0 0 0-3-3z',
  'M3 5h18M6 12h12M10 19h4',
  'M2 12h3l2-7 3 14 3-10 2 5h7',
  'M12 7v5l3 2',
  'M3 3v18h18M7 15l4-4 3 3 6-7',
];
---
<section id="features">
  <div class="container">
    <div class="eyebrow" style="margin-bottom:12px;">{t.features.eyebrow}</div>
    <h2 style="margin-bottom:32px;max-width:720px;">{t.features.h2}</h2>
    <div class="grid-3">
      {feats.map((f, i) => (
        <div class="feat-card">
          <div class="icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d={iconPaths[i % iconPaths.length]} />
              {i === 4 && <circle cx="12" cy="12" r="9" />}
            </svg>
          </div>
          <h4>{f.t}</h4>
          <p>{f.d}</p>
        </div>
      ))}
    </div>
  </div>
</section>
